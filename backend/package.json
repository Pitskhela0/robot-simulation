{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/scripts/migrate.ts",
    "migrate:dev": "cross-env NODE_ENV=development ts-node src/scripts/migrate.ts",
    "migrate:test": "cross-env NODE_ENV=test ts-node src/scripts/migrate.ts",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:db": "cross-env NODE_ENV=test jest src/__tests__/db-connection.test.ts",
    "test:migrations": "cross-env NODE_ENV=test jest src/__tests__/migrations.test.ts",
    "test:api": "cross-env NODE_ENV=test jest src/__tests__/api.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.18",
    "@types/pg": "^8.15.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.0.1",
    "pg": "^8.16.0"
  }
}